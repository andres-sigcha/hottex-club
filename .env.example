# Supabase Postgres (Transaction pooler URI preferred for Prisma)
DATABASE_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT-REF>.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"
NEXT_PUBLIC_BASE_URL="https://your-vercel-domain.vercel.app"

# Admin seed account: admin@hottext.club / admin123!

# Twilio (optional for local demo / phase 1)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
ALLOW_QUIET_HOUR_SENDS="false"
QUIET_HOURS_START="21"
QUIET_HOURS_END="8"

# Cron protection secret for /api/cron/send-scheduled
CRON_SECRET="replace-with-strong-secret"
